#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done

ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"
SETUP="$ROOT/setup"
CMD="${1:-install}"
shift || true

usage() {
  cat >&2 <<'EOF'
Usage: gstack [install|setup] [--host claude|codex|gemini|auto]

Commands:
  install   Materialize the canonical runtime in ~/.gstack and register host entrypoints
  setup     Alias for install
  upgrade   Use the /gstack-upgrade skill from your agent host
EOF
}

case "$CMD" in
  install|setup)
    if [ ! -x "$SETUP" ]; then
      echo "gstack install failed: missing setup script at $SETUP" >&2
      echo "This package is incomplete. Reinstall gstack or run from a full checkout." >&2
      exit 1
    fi
    exec "$SETUP" "$@"
    ;;
  upgrade)
    echo "Use the /gstack-upgrade skill from your agent host." >&2
    exit 1
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 1
    ;;
esac
